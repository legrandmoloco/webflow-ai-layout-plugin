{
  "name": "webflow-ai-layout-plugin",
  "version": "1.0.0",
  "description": "Webflow Designer plugin that generates layouts using Claude Code API",
  "main": "src/main.js",
  "scripts": {
    "build": "webpack --mode=production",
    "dev": "webpack serve --mode=development --open",
    "watch": "webpack --mode=development --watch",
    "serve": "python3 -m http.server 8080",
    "serve-simple": "npx serve . -p 8080",
    "proxy": "node proxy-server.js",
    "start": "node proxy-server.js",
    "vercel-build": "npm run build"
  },
  "devDependencies": {
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0",
    "css-loader": "^6.8.0",
    "style-loader": "^3.3.0"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "express": "^4.18.0",
    "cors": "^2.8.5"
  }
}